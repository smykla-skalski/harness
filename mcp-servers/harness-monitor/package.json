{
  "name": "@harness-monitor/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for automating the Harness Monitor macOS app",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "harness-monitor-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/server.js",
    "test": "npm run build && node --test 'dist/**/*.test.js'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
