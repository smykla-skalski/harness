{
  "version": 1,
  "hooks": {
    "errorOccurred": [
      {
        "type": "command",
        "bash": "harness hook --agent copilot suite:run tool-failure",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "harness hook --agent copilot suite:run tool-result",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "harness agents repo-policy --agent copilot",
        "cwd": ".",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "harness hook --agent copilot suite:run tool-guard",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "harness agents session-stop --agent copilot --project-dir \"$PWD\"",
        "cwd": ".",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "harness hook --agent copilot suite:run guard-stop",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "harness agents session-start --agent copilot --project-dir \"$PWD\"",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "harness agents prompt-submit --agent copilot --project-dir \"$PWD\"",
        "cwd": ".",
        "timeoutSec": 30
      }
    ]
  }
}