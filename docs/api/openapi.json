  "components": {
    "schemas": {
      "DaemonControlResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "DaemonErrorBody": {
        "type": "object",
        "description": "Error envelope returned by daemon handlers on failure.\n\nMirrors the dominant shape produced by `error_status_and_body`\n(`{\"error\": {\"code\", \"message\", \"details\"}}`). A few endpoints emit\nalternate ad-hoc error shapes for specific conditions; those are noted in\nthe relevant operation descriptions.",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/DaemonErrorDetail"
          }
        }
      },
      "DaemonErrorDetail": {
        "type": "object",
        "description": "Structured error detail carried by [`DaemonErrorBody`].",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Stable machine-readable error code (for example `SESSION_SCOPE_DENIED`)."
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional additional context lines."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message."
          }
        }
      },
      "DaemonTelemetryKind": {
        "type": "string",
        "enum": [
          "decode_failure"
        ]
      },
      "DaemonTelemetryRequest": {
        "type": "object",
        "required": [
          "kind",
          "source",
          "message"
        ],
        "properties": {
          "kind": {
            "$ref": "#/components/schemas/DaemonTelemetryKind"
          },
          "message": {
            "type": "string"
          },
          "sample": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "type": "string"
          }
        }
      },
      "DaemonTelemetryResponse": {
        "type": "object",
        "required": [
          "recorded_at"
        ],
        "properties": {
          "recorded_at": {
            "type": "string"
          }
        }
      },
      "GitHubApiDiagnostics": {
        "type": "object",
        "required": [
          "buckets",
          "cooling",
          "last_hour_network_requests",
          "last_hour_graphql_points",
          "cache_hits",
          "cache_stale_hits",
          "cache_deferred_hits",
          "deferred_budget",
          "top_operations"
        ],
        "properties": {
          "buckets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GitHubRateBucketDiagnostics"
            }
          },
          "cache_deferred_hits": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "cache_hits": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "cache_stale_hits": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "cooling": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GitHubCooldownDiagnostics"
            }
          },
          "data_revision": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "deferred_budget": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "last_hour_graphql_points": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "last_hour_network_requests": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "top_operations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GitHubOperationSpendDiagnostics"
            }
          }
        }
      },
      "GitHubCooldownDiagnostics": {
        "type": "object",
        "required": [
          "resource",
          "reason",
          "until_seconds_from_now"
        ],
        "properties": {
          "reason": {
            "type": "string"
          },
          "resource": {
            "type": "string"
          },
          "until_seconds_from_now": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "GitHubOperationSpendDiagnostics": {
        "type": "object",
        "required": [
          "operation",
          "network_requests",
          "graphql_points"
        ],
        "properties": {
          "graphql_points": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "network_requests": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "operation": {
            "type": "string"
          }
        }
      },
      "GitHubRateBucketDiagnostics": {
        "type": "object",
        "required": [
          "resource",
          "remaining",
          "limit",
          "used",
          "reset_at"
        ],
        "properties": {
          "limit": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "remaining": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "reset_at": {
            "type": "string"
          },
          "resource": {
            "type": "string"
          },
          "used": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "version",
          "pid",
          "endpoint",
          "started_at",
          "log_level",
          "project_count",
          "worktree_count",
          "session_count"
        ],
        "properties": {
          "endpoint": {
            "type": "string"
          },
          "log_level": {
            "type": "string"
          },
          "pid": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "project_count": {
            "type": "integer",
            "minimum": 0
          },
          "session_count": {
            "type": "integer",
            "minimum": 0
          },
          "started_at": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "wire_version": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "worktree_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "LogLevelResponse": {
        "type": "object",
        "required": [
          "level",
          "filter"
        ],
        "properties": {
          "filter": {
            "type": "string"
          },
          "level": {
            "type": "string"
          }
        }
      },
      "ProjectSummary": {
        "type": "object",
        "required": [
          "project_id",
          "name",
          "context_root",
          "active_session_count",
          "total_session_count",
          "worktrees"
        ],
        "properties": {
          "active_session_count": {
            "type": "integer",
            "minimum": 0
          },
          "context_root": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "project_dir": {
            "type": [
              "string",
              "null"
            ]
          },
          "project_id": {
            "type": "string"
          },
          "total_session_count": {
            "type": "integer",
            "minimum": 0
          },
          "worktrees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorktreeSummary"
            }
          }
        }
      },
      "ReadinessResponse": {
        "type": "object",
        "description": "Lightweight readiness probe response.\n\nReturned by `GET /v1/ready`. Confirms the daemon is serving HTTP, the\ncaller is authenticated, and the backing storage slot is wired up - but\nintentionally avoids any database query so short-lived CLI invocations can\nverify readiness cheaply.",
        "required": [
          "ready",
          "daemon_epoch"
        ],
        "properties": {
          "daemon_epoch": {
            "type": "string"
          },
          "ready": {
            "type": "boolean"
          }
        }
      },
      "ResolvedRuntimeSessionAgent": {
        "type": "object",
        "required": [
          "orchestration_session_id",
          "session_agent_id"
        ],
        "properties": {
          "orchestration_session_id": {
            "type": "string"
          },
          "session_agent_id": {
            "type": "string"
          }
        }
      },
      "RuntimeSessionResolutionResponse": {
        "type": "object",
        "description": "Wire-level outcome of a runtime-session lookup.\n\nReturned by `GET /v1/runtime-sessions/resolve`. `resolved` is `None` when\nno live agent matches; `Some` carries the single unambiguous match. The\ndaemon surfaces ambiguity as a `session_ambiguous` error instead of\npopulating this response with multiple entries.",
        "properties": {
          "resolved": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResolvedRuntimeSessionAgent"
              }
            ]
          }
        }
      },
      "SetLogLevelRequest": {
        "type": "object",
        "required": [
          "level"
        ],
        "properties": {
          "level": {
            "type": "string"
          }
        }
      },
      "WorktreeSummary": {
        "type": "object",
        "required": [
          "checkout_id",
          "name",
          "checkout_root",
          "context_root",
          "active_session_count",
          "total_session_count"
        ],
        "properties": {
          "active_session_count": {
            "type": "integer",
            "minimum": 0
          },
          "checkout_id": {
            "type": "string"
          },
          "checkout_root": {
            "type": "string"
          },
          "context_root": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "total_session_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "responses": {
      "RemoteAuthRequired": {
        "description": "Missing, invalid, or unauthorized daemon credentials",
