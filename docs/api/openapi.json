          "200": {
            "description": "Updated daemon log level",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogLevelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Request error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DaemonErrorBody"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/RemoteAuthRequired"
          },
          "414": {
            "$ref": "#/components/responses/RemoteRequestUriTooLong"
