      "panel-5": {
        "kind": "Panel",
        "spec": {
          "id": 5,
          "title": "Span Rate by Service and Span",
          "description": "Runtime span throughput split by service and span name.",
          "links": [
            {
              "title": "Open Traces Breakdown",
              "url": "/a/grafana-exploretraces-app/explore?from=now-30m&to=now&timezone=browser&var-ds=tempo&var-primarySignal=nestedSetParent%3C0&var-filters=&var-metric=rate&var-groupBy=resource.service.name&var-spanListColumns=&var-latencyThreshold=&var-partialLatencyThreshold=&var-durationPercentiles=0.9&actionView=breakdown",
              "targetBlank": false
            }
          ],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "prometheus"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "sum by (service_name, span_name) (rate(harness_spanmetrics_calls_total{service_name=~\"${service_name:regex}\", span_name=~\"${span_name:regex}\"}[5m]))",
                        "legendFormat": "{{service_name}} :: {{span_name}}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "",
            "spec": {
              "options": {
                "legend": {
                  "displayMode": "table",
                  "placement": "bottom"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "reqps",
                  "color": {
                    "mode": "palette-classic"
                  }
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-6": {
        "kind": "Panel",
        "spec": {
          "id": 6,
          "title": "Span p95 by Service and Span",
          "description": "Runtime span p95 latency split by service and span name.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
