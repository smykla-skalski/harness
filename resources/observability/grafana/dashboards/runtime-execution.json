      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service_name, span_name) (rate(harness_spanmetrics_calls_total{service_name=~\"${service_name:regex}\", span_name=~\"${span_name:regex}\"}[5m]))",
          "legendFormat": "{{service_name}} :: {{span_name}}",
          "refId": "A"
        }
      ],
