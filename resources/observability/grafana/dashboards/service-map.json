                "name": "panel-3"
              }
            }
          },
          {
            "kind": "AutoGridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-4"
              }
            }
          },
          {
            "kind": "AutoGridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-5"
              }
            }
          },
          {
            "kind": "AutoGridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-6"
              }
            }
          },
          {
            "kind": "AutoGridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-7"
              }
            }
          },
          {
            "kind": "AutoGridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-8"
              }
            }
          },
          {
            "kind": "AutoGridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-9"
              }
            }
          }
        ]
      }
    },
    "links": [
      {
        "title": "Investigation Cockpit",
        "type": "link",
        "icon": "external link",
        "tooltip": "",
        "url": "/d/harness-investigation-cockpit",
        "tags": [],
        "asDropdown": false,
        "targetBlank": false,
        "includeVars": true,
        "keepTime": true
      },
      {
        "title": "Tempo Explore Service Graph",
        "type": "link",
        "icon": "external link",
        "tooltip": "",
        "url": "/explore?schemaVersion=1&panes=%7B%22A%22%3A%7B%22datasource%22%3A%22tempo%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22uid%22%3A%22tempo%22%2C%22type%22%3A%22tempo%22%7D%2C%22queryType%22%3A%22serviceMap%22%2C%22filters%22%3A%5B%5D%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-30m%22%2C%22to%22%3A%22now%22%7D%7D%7D",
        "tags": [],
        "asDropdown": false,
        "targetBlank": false,
        "includeVars": false,
        "keepTime": false
      },
      {
        "title": "Traces Breakdown",
        "type": "link",
        "icon": "external link",
        "tooltip": "",
        "url": "/a/grafana-exploretraces-app/explore?from=now-30m&to=now&timezone=browser&var-ds=tempo&var-primarySignal=nestedSetParent%3C0&var-filters=&var-metric=rate&var-groupBy=resource.service.name&var-spanListColumns=&var-latencyThreshold=&var-partialLatencyThreshold=&var-durationPercentiles=0.9&actionView=breakdown",
        "tags": [],
        "asDropdown": false,
        "targetBlank": false,
        "includeVars": false,
        "keepTime": false
      }
    ],
    "liveNow": false,
    "preload": false,
    "tags": [
      "harness",
      "observability",
      "service-flow"
    ],
    "timeSettings": {
      "from": "now-15m",
      "to": "now",
      "autoRefresh": "10s",
      "hideTimepicker": false,
      "fiscalYearStartMonth": 0
    },
    "title": "Harness Service Flow",
    "variables": [
      {
        "kind": "QueryVariable",
        "spec": {
          "name": "service_name",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "label": "Service",
          "hide": "dontHide",
          "refresh": "onDashboardLoad",
          "skipUrlSync": false,
          "query": {
            "kind": "DataQuery",
            "group": "prometheus",
            "version": "v0",
            "datasource": {
              "name": "prometheus"
            },
            "spec": {
              "expr": "label_values(harness_spanmetrics_calls_total, service_name)"
            }
          },
          "regex": "",
          "sort": "alphabeticalAsc",
          "definition": "label_values(harness_spanmetrics_calls_total, service_name)",
          "options": [],
          "multi": true,
          "includeAll": true,
          "allValue": ".+",
          "allowCustomValue": true
        }
      }
    ]
  },
  "status": {}
}
