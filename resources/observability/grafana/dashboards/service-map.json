        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, client, server) (rate(traces_service_graph_request_server_seconds_bucket{client=~\"${service_name:regex}\",server=~\"${service_name:regex}\"}[5m])))",
          "legendFormat": "{{client}} -> {{server}}",
          "refId": "A"
        }
