      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=~\"${service_name:regex}\",span_kind=\"SPAN_KIND_SERVER\"}[5m])) or on() vector(0)",
          "refId": "A"
        }
      ],
      "title": "Server Span Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Per-edge request rate using Tempo service-graph metrics.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
