          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (client, server) (rate(traces_service_graph_request_total{client=~\"${service_name:regex}\",server=~\"${service_name:regex}\"}[5m]))",
          "legendFormat": "{{client}} -> {{server}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Edge",
      "type": "timeseries"
    },
    {
