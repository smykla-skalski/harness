        "definition": "label_values(harness_spanmetrics_calls_total{span_name=\"perf.view.body\"}, harness_view_name)",
        "includeAll": true,
        "label": "View",
        "multi": true,
        "name": "view",
        "options": [],
        "query": "label_values(harness_spanmetrics_calls_total{span_name=\"perf.view.body\"}, harness_view_name)",
