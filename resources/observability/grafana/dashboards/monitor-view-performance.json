          "legendFormat": "{{harness_view_display_mode}}",
          "refId": "A"
        }
      ],
      "title": "Toolbar render rate by display mode",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Monitor client logs scoped to view-profiling diagnostics and warnings.",
      "gridPos": {
        "h": 8,
