          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (harness_view_surface) (rate(harness_spanmetrics_calls_total{span_name=\"perf.view.body\", harness_view_surface!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{harness_view_surface}}",
          "refId": "A"
        }
      ],
      "title": "Render rate by content surface",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Toolbar body render rate split by display mode. The toolbar recomputes its layout when available width crosses a breakpoint.",
      "fieldConfig": {
        "defaults": {
