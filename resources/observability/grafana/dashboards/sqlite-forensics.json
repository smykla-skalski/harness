      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(harness_daemon_db_operations_total[5m])) or on() vector(0)",
          "refId": "A"
        }
      ],
      "title": "Daemon DB Ops / s",
      "type": "stat"
    },
