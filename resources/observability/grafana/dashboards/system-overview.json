  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Total traced span throughput across the selected harness services.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "links": [
        {
          "keepTime": true,
          "targetBlank": false,
          "title": "Open Metrics Drilldown",
          "url": "/a/grafana-metricsdrilldown-app/drilldown"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(harness_spanmetrics_calls_total{service_name=~\"${service_name:regex}\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "Span Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Non-allow hook outcomes. This should normally stay near zero.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "links": [
        {
          "keepTime": true,
          "targetBlank": false,
          "title": "Open Runtime Dashboard",
          "url": "/d/harness-runtime-execution"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(harness_hook_outcomes_total{hook_outcome!=\"allow\"}[5m])) or on() vector(0)",
          "refId": "A"
        }
      ],
      "title": "Hook Blocks / s",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Daemon server latency using the current millisecond histogram family.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "links": [
        {
          "keepTime": true,
          "targetBlank": false,
          "title": "Open Daemon Transport Dashboard",
          "url": "/d/harness-daemon-transport"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "((histogram_quantile(0.95, sum by (le) (rate(harness_daemon_http_duration_milliseconds_bucket[5m]))) and on() (sum(rate(harness_daemon_http_duration_milliseconds_count[5m])) > 0)) or on() vector(0))",
          "refId": "A"
        }
      ],
      "title": "Daemon HTTP p95",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Monitor client latency using the real harness-monitor histogram family.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 150
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "links": [
        {
          "keepTime": true,
          "targetBlank": false,
          "title": "Open Monitor Dashboard",
          "url": "/d/harness-monitor-client"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "((histogram_quantile(0.95, sum by (le) (rate(harness_monitor_http_request_duration_ms_bucket[5m]))) and on() (sum(rate(harness_monitor_http_request_duration_ms_count[5m])) > 0)) or on() vector(0))",
          "refId": "A"
        }
      ],
      "title": "Monitor HTTP p95",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Cross-service traced throughput grouped by service_name.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "links": [
        {
          "keepTime": false,
          "targetBlank": false,
          "title": "Open Traces Breakdown",
          "url": "/a/grafana-exploretraces-app/explore?from=now-30m&to=now&timezone=browser&var-ds=tempo&var-primarySignal=nestedSetParent%3C0&var-filters=&var-metric=rate&var-groupBy=resource.service.name&var-spanListColumns=&var-latencyThreshold=&var-partialLatencyThreshold=&var-durationPercentiles=0.9&actionView=breakdown"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(harness_spanmetrics_calls_total{service_name=~\"${service_name:regex}\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "Cross-Service Span Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Cross-service p95 latency derived from the current spanmetrics histogram family.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "links": [
        {
          "keepTime": true,
          "targetBlank": false,
          "title": "Open Metrics Drilldown",
          "url": "/a/grafana-metricsdrilldown-app/drilldown"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(harness_spanmetrics_duration_milliseconds_bucket{service_name=~\"${service_name:regex}\"}[5m])))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "Cross-Service Span p95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Error-oriented signals across hooks, daemon client transport, and monitor HTTP requests.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(harness_hook_outcomes_total{hook_outcome!=\"allow\"}[5m])) or on() vector(0)",
          "legendFormat": "hook blocks",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(harness_daemon_client_requests_total{error=\"true\"}[5m])) or on() vector(0)",
          "legendFormat": "daemon client errors",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(harness_monitor_http_requests_total{request_failed=\"true\"}[5m])) or on() vector(0)",
          "legendFormat": "monitor failed requests",
          "refId": "C"
        }
      ],
      "title": "Error Signals",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Logs filtered for the selected services and severity levels. Use this as the landing page for drilldown into failure detail.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 8,
      "links": [
        {
          "keepTime": true,
          "targetBlank": false,
          "title": "Open Logs Drilldown",
          "url": "/a/grafana-lokiexplore-app/explore"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "{service_name=~\"${service_name:regex}\", level=~\"${level:regex}\"} |~ \"(?i)error|fail|denied|panic\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Error Logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "harness",
    "observability",
    "overview"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service_name",
        "options": [],
        "query": "harness-cli,harness-hook,harness-daemon,harness-bridge,harness-monitor",
        "type": "custom"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "label": "Level",
        "multi": true,
        "name": "level",
        "options": [],
        "query": "debug,info,warn,error",
        "type": "custom"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Harness System Overview",
  "uid": "harness-system-overview",
