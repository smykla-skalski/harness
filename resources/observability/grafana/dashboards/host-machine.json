      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "Memory Pressure",
          "description": "Memory pressure derived from active, wired, and compressed memory.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
