                      "spec": {
                        "editorMode": "code",
                        "expr": "topk(10, sum by (process_executable_name) (process_memory_usage_bytes{process_executable_name=~\"$process_name\"}))",
                        "legendFormat": "{{process_executable_name}}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
