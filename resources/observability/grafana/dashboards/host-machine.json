      "panel-2": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Load / Core",
          "description": "Load average normalized by logical core count.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "prometheus"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "node_load1 / scalar(clamp_min(count(count by (cpu) (node_cpu_seconds_total{mode=\"idle\"})), 1))"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "stat",
            "version": "",
            "spec": {
              "options": {
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "auto",
                "orientation": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "textMode": "value"
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "none",
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": 0,
                        "color": "green"
                      },
                      {
                        "value": 0.7,
                        "color": "orange"
                      },
                      {
                        "value": 1,
                        "color": "red"
                      }
                    ]
                  },
                  "color": {
                    "mode": "thresholds"
