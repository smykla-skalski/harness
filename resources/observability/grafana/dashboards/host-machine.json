      "panel-6": {
        "kind": "Panel",
        "spec": {
          "id": 6,
          "title": "Filesystem Fill by Mountpoint",
          "description": "Filesystem fill ratio, filtered through the mountpoint selector.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
