{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "harness-host-machine"
  },
  "spec": {
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "query": {
            "kind": "DataQuery",
            "group": "grafana",
            "version": "v0",
            "datasource": {
              "name": "-- Grafana --"
            },
            "spec": {}
          },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "builtIn": true,
          "legacyOptions": {
            "type": "dashboard"
          }
        }
      },
      {
        "kind": "AnnotationQuery",
        "spec": {
          "name": "Deployments",
          "enable": true,
          "hide": false,
          "iconColor": "rgba(0, 211, 255, 1)",
          "query": {
            "kind": "DataQuery",
            "group": "loki",
            "version": "v0",
            "datasource": {
              "name": "loki"
            },
            "spec": {
              "expr": "{service_name=~\"harness-daemon|harness-monitor\"} |~ \"(?i)(starting|shutdown|version=)\"",
              "refId": "DEPLOY",
              "maxLines": 100
            }
          }
        }
      }
    ],
    "cursorSync": "Crosshair",
    "editable": true,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "CPU Busy",
          "description": "CPU busy ratio from the Alloy unix exporter.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "prometheus"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "stat",
            "version": "",
            "spec": {
              "options": {
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "auto",
                "orientation": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "textMode": "value"
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "percentunit",
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": 0,
                        "color": "green"
                      },
                      {
                        "value": 0.6,
                        "color": "orange"
                      },
                      {
                        "value": 0.85,
                        "color": "red"
                      }
                    ]
                  },
                  "color": {
                    "mode": "thresholds"
                  }
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-11": {
        "kind": "Panel",
        "spec": {
          "id": 11,
          "title": "Network I/O by Interface",
          "description": "Receive and transmit throughput by network interface from the Alloy unix exporter.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "prometheus"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "sum by (device) (rate(node_network_receive_bytes_total{device!~\"lo0|utun.*|awdl0|llw0\"}[5m]))",
                        "legendFormat": "recv {{device}}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "prometheus"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "sum by (device) (rate(node_network_transmit_bytes_total{device!~\"lo0|utun.*|awdl0|llw0\"}[5m]))",
                        "legendFormat": "tx {{device}}"
                      }
                    },
                    "refId": "B",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "",
            "spec": {
              "options": {
                "legend": {
                  "displayMode": "table",
                  "placement": "bottom"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "Bps",
                  "color": {
                    "mode": "palette-classic"
                  }
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-12": {
        "kind": "Panel",
        "spec": {
          "id": 12,
          "title": "Process States",
          "description": "Whole-machine process counts by status from the Alloy OTel host-process exporter.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "prometheus"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "sum by (status) (system_processes_count)",
                        "legendFormat": "{{status}}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "",
            "spec": {
              "options": {
                "legend": {
                  "displayMode": "table",
                  "placement": "bottom"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "color": {
                    "mode": "palette-classic"
                  }
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-13": {
        "kind": "Panel",
        "spec": {
          "id": 13,
          "title": "Tracked Process CPU",
          "description": "Top tracked workstation processes by CPU utilization. Queries aggregate by executable name to avoid PID-level cardinality.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "prometheus"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "topk(10, sum by (process_executable_name) (process_cpu_utilization_ratio{state=~\"system|user\",process_executable_name=~\"$process_name\"}))",
                        "legendFormat": "{{process_executable_name}}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "",
            "spec": {
              "options": {
                "legend": {
                  "calcs": [
                    "lastNotNull",
                    "max",
                    "mean"
                  ],
                  "displayMode": "table",
                  "placement": "bottom"
                },
                "tooltip": {
                  "mode": "multi",
                  "sort": "desc"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "percentunit",
                  "color": {
                    "mode": "palette-classic"
                  }
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-14": {
        "kind": "Panel",
        "spec": {
          "id": 14,
          "title": "Tracked Process RSS",
          "description": "Resident memory for the curated tracked process set, aggregated by executable name.",
          "links": [],
