        },
        "definition": "label_values(harness_monitor_http_requests_total, url_path)",
        "includeAll": true,
        "label": "Path",
        "multi": true,
        "name": "url_path",
        "options": [],
        "query": "label_values(harness_monitor_http_requests_total, url_path)",
        "refresh": 1,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
