  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Monitor HTTP request throughput from the real harness_monitor_http_requests_total metric.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(harness_monitor_http_requests_total{url_path=~\"${url_path:regex}\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "HTTP Req / s",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Monitor HTTP p95 latency from the millisecond histogram family.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 150
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "((histogram_quantile(0.95, sum by (le) (rate(harness_monitor_http_request_duration_ms_bucket{url_path=~\"${url_path:regex}\"}[5m]))) and on() (sum(rate(harness_monitor_http_request_duration_ms_count{url_path=~\"${url_path:regex}\"}[5m])) > 0)) or on() vector(0))",
          "refId": "A"
        }
      ],
      "title": "HTTP p95",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "WebSocket reconnect and start counters. This remains empty until the monitor exercises the daemon socket path.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(harness_monitor_websocket_connects_total[5m]))",
          "refId": "A"
        }
      ],
      "title": "WS Connects / s",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "WebSocket RPC p95 latency. Empty until monitor websocket RPCs are exercised.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 150
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "((histogram_quantile(0.95, sum by (le) (rate(harness_monitor_websocket_rpc_duration_ms_bucket[5m]))) and on() (sum(rate(harness_monitor_websocket_rpc_duration_ms_count[5m])) > 0)) or on() vector(0))",
          "refId": "A"
        }
      ],
      "title": "WS RPC p95",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "HTTP throughput by path and status code.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "links": [
        {
          "keepTime": true,
          "targetBlank": false,
          "title": "Open Metrics Drilldown",
          "url": "/a/grafana-metricsdrilldown-app/drilldown"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (url_path, http_response_status_code) (rate(harness_monitor_http_requests_total{url_path=~\"${url_path:regex}\"}[5m]))",
          "legendFormat": "{{url_path}} :: {{http_response_status_code}}",
          "refId": "A"
        }
      ],
      "title": "HTTP Rate by Path and Status",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "HTTP p95 latency by path.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, url_path) (rate(harness_monitor_http_request_duration_ms_bucket{url_path=~\"${url_path:regex}\"}[5m])))",
          "legendFormat": "{{url_path}}",
          "refId": "A"
        }
      ],
      "title": "HTTP p95 by Path",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "WebSocket signals by outcome and RPC failure state.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (connect_outcome) (rate(harness_monitor_websocket_connects_total[5m]))",
          "legendFormat": "connect {{connect_outcome}}",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (rpc_failed) (rate(harness_monitor_websocket_rpc_duration_ms_count[5m]))",
          "legendFormat": "rpc failed={{rpc_failed}}",
          "refId": "B"
        }
      ],
      "title": "WebSocket Signals",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Harness Monitor logs for the selected severity levels.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 8,
      "links": [
        {
          "keepTime": true,
          "targetBlank": false,
          "title": "Open Logs Drilldown",
          "url": "/a/grafana-lokiexplore-app/explore"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "{service_name=\"harness-monitor\", level=~\"${level:regex}\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Monitor Logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "harness",
