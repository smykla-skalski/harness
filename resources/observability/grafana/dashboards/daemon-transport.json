        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(harness_daemon_client_duration_milliseconds_bucket{http_route=~\"${http_route:regex}\"}[5m])))",
          "legendFormat": "client p95 ms",
          "refId": "D"
        }
