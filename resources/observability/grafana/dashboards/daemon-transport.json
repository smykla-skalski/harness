      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * ((sum(rate(harness_daemon_http_requests_total{http_route=~\"${http_route:regex}\", http_status_code=~\"5..\"}[5m])) or on() vector(0)) / clamp_min(sum(rate(harness_daemon_http_requests_total{http_route=~\"${http_route:regex}\"}[5m])), 0.001))",
          "legendFormat": "server 5xx %",
          "refId": "A"
