        {
          "editorMode": "code",
          "expr": "100 * ((sum(rate(harness_daemon_client_requests_total{http_route=~\"${http_route:regex}\", error=\"true\"}[5m])) or on() vector(0)) / clamp_min(sum(rate(harness_daemon_client_requests_total{http_route=~\"${http_route:regex}\"}[5m])), 0.001))",
          "legendFormat": "client error %",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(harness_daemon_http_duration_milliseconds_bucket{http_route=~\"${http_route:regex}\"}[5m])))",
