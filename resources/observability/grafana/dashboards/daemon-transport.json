    "title": "Harness Daemon Transport",
    "variables": [
      {
        "kind": "QueryVariable",
        "spec": {
          "name": "http_route",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "label": "Route",
          "hide": "dontHide",
          "refresh": "onDashboardLoad",
          "skipUrlSync": false,
          "query": {
            "kind": "DataQuery",
            "group": "prometheus",
            "version": "v0",
            "datasource": {
              "name": "prometheus"
            },
            "spec": {
              "expr": "label_values(harness_daemon_http_requests_total, http_route)"
            }
          },
          "regex": "",
          "sort": "alphabeticalAsc",
          "definition": "label_values(harness_daemon_http_requests_total, http_route)",
          "options": [],
          "multi": true,
          "includeAll": true,
          "allValue": ".*",
          "allowCustomValue": true
        }
      },
      {
        "kind": "QueryVariable",
        "spec": {
          "name": "http_status_code",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "label": "Status",
          "hide": "dontHide",
          "refresh": "onDashboardLoad",
          "skipUrlSync": false,
          "query": {
            "kind": "DataQuery",
            "group": "prometheus",
            "version": "v0",
            "datasource": {
              "name": "prometheus"
            },
            "spec": {
              "expr": "label_values(harness_daemon_http_requests_total, http_status_code)"
