# Harness Observability Stack Configuration
# Copy to .env and customize values

# SQLite database paths (required)
HARNESS_SQLITE_EXPORTER_DAEMON_DIR=/path/to/daemon/db
HARNESS_SQLITE_EXPORTER_MONITOR_DIR=/path/to/monitor/db

# Grafana settings (optional, defaults shown)
GF_USERS_DEFAULT_THEME=light
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=harness
GF_ALERTING_EMAIL_ADDRESSES=admin@localhost
