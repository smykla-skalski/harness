# Harness Observability Stack Configuration
# Copy to .env and customize values as needed.
#
# scripts/observability.sh can start from a clean checkout without this file.
# Use these overrides when the helper should discover SQLite data from a non-default location.
HARNESS_DAEMON_DATA_HOME=/path/to/harness/data/home
HARNESS_APP_GROUP_ID=Q498EB36N4.io.harnessmonitor
#
# If you bypass scripts/observability.sh and run docker compose directly, set all four sqlite mounts.
HARNESS_SQLITE_SOURCE_DAEMON_DIR=/path/to/daemon/db/dir
HARNESS_SQLITE_SOURCE_MONITOR_DIR=/path/to/monitor/cache/dir
HARNESS_SQLITE_SNAPSHOT_DAEMON_DIR=/path/to/runtime/snapshots/daemon
HARNESS_SQLITE_SNAPSHOT_MONITOR_DIR=/path/to/runtime/snapshots/monitor

# Grafana settings (optional, defaults shown)
GF_USERS_DEFAULT_THEME=light
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=harness
GF_ALERTING_EMAIL_ADDRESSES=admin@localhost
