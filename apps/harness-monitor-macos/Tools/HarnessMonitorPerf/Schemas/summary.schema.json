{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/smykla-skalski/harness/apps/harness-monitor-macos/Tools/HarnessMonitorPerf/Schemas/summary.schema.json",
  "title": "Harness Monitor audit summary",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "captures"
  ],
  "properties": {
    "label": { "type": ["string", "null"] },
    "created_at_utc": { "type": ["string", "null"] },
    "git": {},
    "system": {},
    "targets": {},
    "selected_scenarios": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "warnings": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "captures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "scenario",
          "template"
        ],
        "properties": {
          "scenario": { "type": "string" },
          "template": { "type": "string" },
          "duration_seconds": { "type": ["number", "null"] },
          "trace_relpath": { "type": ["string", "null"] },
          "exit_status": { "type": ["integer", "null"] },
          "end_reason": { "type": ["string", "null"] },
          "warnings": {
            "type": ["array", "null"],
            "items": { "type": "string" }
          },
          "launch_metrics": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": [
              "app_init_to_ready_ms",
              "measured_from",
              "state_label",
              "window_id",
              "includes_bootstrap_in_scenario_measurement"
            ],
            "properties": {
              "app_init_to_ready_ms": { "type": "number" },
              "measured_from": { "type": "string" },
              "state_label": { "type": "string" },
              "window_id": { "type": "string" },
              "includes_bootstrap_in_scenario_measurement": { "type": "boolean" }
            }
          },
          "metric_tiers": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["hard_budget", "investigative"],
            "properties": {
              "hard_budget": {
                "type": "array",
                "items": { "type": "string" }
              },
              "investigative": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "metrics": {
            "description": "Free-form extracted metrics payload keyed by template-specific extractor output."
          }
        }
      }
    }
  }
}
