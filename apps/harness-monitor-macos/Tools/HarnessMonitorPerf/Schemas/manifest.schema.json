{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/smykla-skalski/harness/apps/harness-monitor-macos/Tools/HarnessMonitorPerf/Schemas/manifest.schema.json",
  "title": "Harness Monitor audit manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "label",
    "run_id",
    "created_at_utc",
    "git",
    "system",
    "targets",
    "build_provenance",
    "templates",
    "default_environment",
    "launch_arguments",
    "selected_scenarios",
    "captures"
  ],
  "properties": {
    "label": { "type": "string" },
    "run_id": { "type": "string" },
    "created_at_utc": { "type": "string" },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "dirty", "workspace_fingerprint", "build_started_at_utc"],
      "properties": {
        "commit": { "type": "string" },
        "dirty": { "type": "boolean" },
        "workspace_fingerprint": { "type": "string" },
        "build_started_at_utc": { "type": "string" }
      }
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xcode_version", "xctrace_version", "macos_version", "macos_build", "arch"],
      "properties": {
        "xcode_version": { "type": "string" },
        "xctrace_version": { "type": "string" },
        "macos_version": { "type": "string" },
        "macos_build": { "type": "string" },
        "arch": { "type": "string" }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "shipping_scheme",
        "host_scheme",
        "shipping_app_path",
        "host_app_path",
        "host_bundle_id",
        "staged_host_app_path",
        "staged_host_binary_path",
        "staged_host_bundle_id"
      ],
      "properties": {
        "project": { "type": "string" },
        "shipping_scheme": { "type": "string" },
        "host_scheme": { "type": "string" },
        "shipping_app_path": { "type": "string" },
        "host_app_path": { "type": "string" },
        "host_bundle_id": { "type": "string" },
        "staged_host_app_path": { "type": "string" },
        "staged_host_binary_path": { "type": "string" },
        "staged_host_bundle_id": { "type": "string" }
      }
    },
    "build_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audit_daemon_bundle", "host", "shipping"],
      "properties": {
        "audit_daemon_bundle": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requested_skip", "mode", "cargo_target_dir"],
          "properties": {
            "requested_skip": { "type": "boolean" },
            "mode": { "type": "string" },
            "cargo_target_dir": { "type": "string" }
          }
        },
        "host": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "embedded_commit",
            "embedded_dirty",
            "embedded_workspace_fingerprint",
            "embedded_started_at_utc",
            "binary_sha256",
            "bundle_sha256",
            "binary_mtime_utc"
          ],
          "properties": {
            "embedded_commit": { "type": "string" },
            "embedded_dirty": { "type": "string" },
            "embedded_workspace_fingerprint": { "type": "string" },
            "embedded_started_at_utc": { "type": "string" },
            "binary_sha256": { "type": "string" },
            "bundle_sha256": { "type": "string" },
            "binary_mtime_utc": { "type": "string" }
          }
        },
        "shipping": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "built",
            "embedded_commit",
            "embedded_dirty",
            "embedded_workspace_fingerprint",
            "embedded_started_at_utc",
            "binary_sha256",
            "bundle_sha256",
            "binary_mtime_utc"
          ],
          "properties": {
            "built": { "type": "boolean" },
            "embedded_commit": { "type": "string" },
            "embedded_dirty": { "type": "string" },
            "embedded_workspace_fingerprint": { "type": "string" },
            "embedded_started_at_utc": { "type": "string" },
            "binary_sha256": { "type": "string" },
            "bundle_sha256": { "type": "string" },
            "binary_mtime_utc": { "type": "string" }
          }
        }
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["swiftui", "allocations"],
      "properties": {
        "swiftui": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allocations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "default_environment": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "launch_arguments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "selected_scenarios": {
      "type": "array",
      "items": { "type": "string" }
    },
    "captures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scenario",
          "template",
          "duration_seconds",
          "trace_relpath",
          "exit_status",
          "end_reason",
          "preview_scenario",
          "launched_process_path",
          "environment",
          "launch_arguments",
          "daemon_data_home_probe",
          "metric_tiers"
        ],
        "properties": {
          "scenario": { "type": "string" },
          "template": { "type": "string" },
          "duration_seconds": { "type": "integer" },
          "trace_relpath": { "type": "string" },
          "app_trace_relpath": { "type": ["string", "null"] },
          "exit_status": { "type": "integer" },
          "end_reason": { "type": "string" },
          "preview_scenario": { "type": "string" },
          "launched_process_path": { "type": "string" },
          "environment": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "launch_arguments": {
            "type": "array",
            "items": { "type": "string" }
          },
          "daemon_data_home_probe": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "data_home",
              "exists",
              "regular_file_count",
              "total_bytes",
              "contains_daemon_manifest",
              "contains_sqlite_database",
              "contains_sqlite_wal",
              "contains_sqlite_shm"
            ],
            "properties": {
              "data_home": { "type": "string" },
              "exists": { "type": "boolean" },
              "regular_file_count": { "type": "integer" },
              "total_bytes": { "type": "integer" },
              "contains_daemon_manifest": { "type": "boolean" },
              "contains_sqlite_database": { "type": "boolean" },
              "contains_sqlite_wal": { "type": "boolean" },
              "contains_sqlite_shm": { "type": "boolean" }
            }
          },
          "launch_metrics": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "app_init_to_ready_ms",
              "measured_from",
              "state_label",
              "window_id",
              "includes_bootstrap_in_scenario_measurement"
            ],
            "properties": {
              "app_init_to_ready_ms": { "type": "number" },
              "measured_from": { "type": "string" },
              "state_label": { "type": "string" },
              "window_id": { "type": "string" },
              "includes_bootstrap_in_scenario_measurement": { "type": "boolean" }
            }
          },
          "metric_tiers": {
            "type": "object",
            "additionalProperties": false,
            "required": ["hard_budget", "investigative"],
            "properties": {
              "hard_budget": {
                "type": "array",
                "items": { "type": "string" }
              },
              "investigative": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
