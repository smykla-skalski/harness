{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/smykla-skalski/harness/apps/harness-monitor-macos/Tools/HarnessMonitorPerf/Schemas/comparison.schema.json",
  "title": "Harness Monitor audit comparison",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "missing_from_current",
    "missing_from_baseline",
    "current_missing_metrics",
    "baseline_missing_metrics",
    "comparisons"
  ],
  "properties": {
    "current_label": { "type": ["string", "null"] },
    "baseline_label": { "type": ["string", "null"] },
    "current_created_at_utc": { "type": ["string", "null"] },
    "baseline_created_at_utc": { "type": ["string", "null"] },
    "missing_from_current": {
      "type": "array",
      "items": { "$ref": "#/$defs/missingCapture" }
    },
    "missing_from_baseline": {
      "type": "array",
      "items": { "$ref": "#/$defs/missingCapture" }
    },
    "current_missing_metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/missingCapture" }
    },
    "baseline_missing_metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/missingCapture" }
    },
    "comparisons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenario", "template", "metrics"],
        "properties": {
          "scenario": { "type": "string" },
          "template": { "type": "string" },
          "metrics": {
            "description": "SwiftUI comparisons encode a flat metric->delta block map; allocations encode category->metric->delta block.",
            "type": "object"
          },
          "shared_metrics": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/deltaBlock" }
          },
          "metric_tiers": {
            "type": "object",
            "additionalProperties": false,
            "required": ["hard_budget", "investigative"],
            "properties": {
              "hard_budget": {
                "type": "array",
                "items": { "type": "string" }
              },
              "investigative": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "baseline_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding" }
          },
          "current_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding" }
          },
          "new_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding" }
          },
          "resolved_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding" }
          },
          "app_trace": {
            "$ref": "#/$defs/appTraceComparison"
          },
          "top_frames": {
            "type": "object",
            "additionalProperties": false,
            "required": ["baseline", "current"],
            "properties": {
              "baseline": {
                "type": "array",
                "items": { "$ref": "#/$defs/frame" }
              },
              "current": {
                "type": "array",
                "items": { "$ref": "#/$defs/frame" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "missingCapture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario", "template"],
      "properties": {
        "scenario": { "type": "string" },
        "template": { "type": "string" },
        "reason": { "type": ["string", "null"] }
      }
    },
    "deltaBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline", "current", "delta"],
      "properties": {
        "baseline": { "type": "number" },
        "current": { "type": "number" },
        "delta": { "type": "number" }
      }
    },
    "componentCount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "count"],
      "properties": {
        "component": { "type": "string" },
        "count": { "type": "integer" }
      }
    },
    "appTraceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_count", "components", "ordered_steps"],
      "properties": {
        "event_count": { "type": "integer" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentCount" }
        },
        "ordered_steps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "appTraceComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["new_steps", "resolved_steps"],
      "properties": {
        "baseline": {
          "oneOf": [
            { "$ref": "#/$defs/appTraceSummary" },
            { "type": "null" }
          ]
        },
        "current": {
          "oneOf": [
            { "$ref": "#/$defs/appTraceSummary" },
            { "type": "null" }
          ]
        },
        "new_steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resolved_steps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "samples"],
      "properties": {
        "name": { "type": "string" },
        "samples": { "type": "integer" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "category", "headline"],
      "properties": {
        "key": { "type": "string" },
        "category": { "type": "string" },
        "headline": { "type": "string" },
        "detail": { "type": ["string", "null"] },
        "count": { "type": ["integer", "null"] }
      }
    }
  }
}
